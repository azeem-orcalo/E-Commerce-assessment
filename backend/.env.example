# ─── Database ──────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE_NAME
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/ecommerce_db

# ─── JWT ───────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_long_random_secret_min_32_chars
JWT_REFRESH_SECRET=replace_with_different_long_random_secret_min_32_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── App ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── CORS ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── Stripe (optional — leave empty to use mock payment) ───────────────────
STRIPE_SECRET_KEY=sk_test_replace_if_using_stripe   # leave empty to disable card payments
